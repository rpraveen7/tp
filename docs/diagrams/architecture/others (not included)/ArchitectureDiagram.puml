@startuml
!pragma layout smetana

rectangle "GitSwole\n(Main)" as Main

rectangle "UI" as UI
rectangle "Parser" as Parser
rectangle "Command" as Command
rectangle "Storage\nHistoryStorage" as Storage

rectangle "Assets\nWorkoutList\nWorkout\nExercise" as Assets
rectangle "Commons\nGitSwoleException" as Commons

Main --> UI      : initializes
Main --> Parser  : initializes
Main --> Storage : initializes

UI      ..> Commons : uses
Parser  --> Command : creates
Parser  ..> Commons : uses
Command --> Assets  : operates on
Command ..> Commons : uses
Storage --> Assets  : reads/writes
Storage ..> Commons : uses

@enduml
