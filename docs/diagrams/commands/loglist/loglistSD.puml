@startuml
title Sequence Diagram: LogListCommand

' Standard scaling parameters to prevent clipping
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

participant "Caller" as Caller
participant ":Parser" as Parser
participant "l:LogListCommand" as Command
participant ":HistoryStorage" as Storage
participant ":Ui" as Ui

Caller -> Parser : parse("loglist")
activate Parser
create Command
Parser -> Command : new LogListCommand(response)
Parser --> Caller : l
deactivate Parser

Caller -> Command : execute(workouts, ui)
activate Command

Command -> Storage : loadHistory()
activate Storage
Storage --> Command : logs: ArrayList<String>
deactivate Storage

alt logs is empty
    Command -> Ui : showError("No history found")
    activate Ui
    Ui --> Command
    deactivate Ui
else
    loop for each log in logs
        Command -> Ui : showMessage(log)
        activate Ui
        Ui --> Command
        deactivate Ui
    end
end

Command --> Caller
deactivate Command

@enduml
